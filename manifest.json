{
  "manifest_version": 3,
  "name": "FCABR Booster",
  "version": "0.1.0",
  "description": "Extensao para enriquecer a experiencia do usuario no site FCABR.",
  "permissions": [
    "tabs"
  ],
  "host_permissions": [
    "*://fcabr.net/*",
    "*://*.fcabr.net/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://fcabr.net/*"
      ],
      "exclude_matches": [
        "https://fcabr.net/api/auth/*"
      ],
      "js": [
        "scripts/content-scripts/content.js"
      ],
      "run_at": "document_start"
    }
  ],"web_accessible_resources": [
    {
      "resources": ["scripts/content-scripts/inject.js"],
      "matches": ["https://fcabr.net/*"]
    }
  ],
  "action": {
    "default_title": "FCABR Booster",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/logo.png",
      "32": "images/logo.png",
      "48": "images/logo.png",
      "128": "images/logo.png"
    }
  },
  "icons": {
    "16": "images/logo.png",
    "32": "images/logo.png",
    "48": "images/logo.png",
    "128": "images/logo.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "contato@ferasgameshosting.com.br",
      "strict_min_version": "109.0"
    }
  }
}
