{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "checkJs": false,
    "allowSyntheticDefaultImports": true,
    "ignoreDeprecations": "6.0",
    "typeRoots": ["./src"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}
